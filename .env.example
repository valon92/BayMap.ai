APP_NAME=BuyMap.ai
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

# BuyMap.ai — stateless MVP (no database required)
# VITE_API_URL=/api   # default — same origin; only set if API is on another host
# VITE_HMR_HOST=192.168.0.111   # optional — set automatically by npm run dev:lan

# Production (Render + Vercel): see docs/DEPLOY.md
# APP_URL=https://buymap.ai
# APP_ENV=production
# APP_DEBUG=false
# LOG_CHANNEL=stderr
POWERBOOK_DEFAULT_CITY=Ferizaj

# AI provider: auto | gemini | openai (auto = Gemini if key set, else OpenAI)
AI_PROVIDER=auto

# Google Gemini — server-side only (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
# Or: GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_ENABLED=true
GEMINI_TIMEOUT=25

# OpenAI — natural language query parsing (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_ENABLED=true
OPENAI_TIMEOUT=20

# eBay Browse API — https://developer.ebay.com/my/keys
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_SANDBOX=false
EBAY_ENABLED=true
EBAY_SEARCH_LIMIT=12

# Universal bridge — Google Shopping + eBay for any country (see UniversalMarketplaceBridge)
UNIVERSAL_BRIDGE_ENABLED=true

# SerpAPI — Google Shopping (many websites) https://serpapi.com/
SERPAPI_KEY=
SERPAPI_ENABLED=true
SERPAPI_LIMIT=12
SERPAPI_GL=de
SERPAPI_HL=en

# Walmart Marketplace — OAuth + catalog search https://developer.walmart.com/us-marketplace/reference/tokenapi
WALMART_ENABLED=true
WALMART_CLIENT_ID=
WALMART_CLIENT_SECRET=
# client_credentials (default) | refresh_token | authorization_code
WALMART_GRANT_TYPE=client_credentials
WALMART_REFRESH_TOKEN=
WALMART_AUTH_CODE=
WALMART_REDIRECT_URI=
WALMART_CONSUMER_CHANNEL_TYPE=
WALMART_MARKET=US
WALMART_SEARCH_LIMIT=20
WALMART_TIMEOUT=20
WALMART_CACHE_TTL=300

# Channel3 — universal product catalog https://docs.trychannel3.com/
CHANNEL3_API_KEY=
CHANNEL3_ENABLED=true
CHANNEL3_LIMIT=20
CHANNEL3_TIMEOUT=25

# Browse AI — browser robots for anti-bot marketplaces https://www.browse.ai/
BROWSE_AI_API_KEY=
BROWSE_AI_ENABLED=false
BROWSE_AI_BASE_URL=https://api.browse.ai/v2
BROWSE_AI_TIMEOUT=60
BROWSE_AI_MAX_WAIT=55
BROWSE_AI_POLL_MS=2000
# CH real estate
BROWSE_AI_ROBOT_HOMEGATE_CH=
BROWSE_AI_ROBOT_IMMOSCOUT24_CH=
BROWSE_AI_ROBOT_NEWHOME_CH=
BROWSE_AI_ROBOT_COMPARIS_IMMO=
# CH/DE automotive
BROWSE_AI_ROBOT_AUTOSCOUT24_CH=
BROWSE_AI_ROBOT_MOBILE_DE=
BROWSE_AI_ROBOT_HEYCAR_DE=
# DE automotive parts (create robots at https://dashboard.browse.ai/)
BROWSE_AI_ROBOT_AUTODOC=
BROWSE_AI_ROBOT_AUTODOC_DE=
BROWSE_AI_ROBOT_KFZTEILE24_DE=
BROWSE_AI_ROBOT_AMAZON_AUTOMOTIVE=
BROWSE_AI_ROBOT_AMAZON_DE=
BROWSE_AI_ROBOT_MISTER_AUTO_DE=
BROWSE_AI_ROBOT_OSCARO_DE=

# Playwright — headless Chromium for anti-bot scraping https://playwright.dev/
PLAYWRIGHT_ENABLED=true
# macOS Homebrew example — run: which node
PLAYWRIGHT_NODE=/opt/homebrew/bin/node
PLAYWRIGHT_TIMEOUT=35
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_WAIT_UNTIL=domcontentloaded
PLAYWRIGHT_WAIT_SELECTOR=
# Comma-separated platform key fragments — Playwright runs first (anti-bot stores)
PLAYWRIGHT_PREFER_PATTERNS=amazon_,mister_auto,oscaro,kfzteile24,mobile_de,heycar_de,autoscout24,ebay

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
